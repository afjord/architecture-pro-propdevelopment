@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title PropDevelopment — C4 Context Diagram (Smart Home Extension)

Person(customer, "Клиент", "Потенциальный покупатель недвижимости")
Person(owner, "Собственник", "Пользователь мобильного приложения и сервисов управляющей компании")
Person(manager, "Менеджер", "Сотрудник операционной команды")
Person(analyst, "Специалист по ИБ", "Участвует в контроле архитектурных решений и безопасности")

System_Boundary(prop, "PropDevelopment") {
    System(mainSystem, "Платформа PropDevelopment", "Набор бизнес-систем для продажи недвижимости, обслуживания собственников, финансового учёта и интеграции с сервисами умного дома")
}

System_Ext(mc, "Управляющие компании", "Партнёрские системы для оплаты ЖКУ и получения информации о доме")
System_Ext(gov, "Госорганы", "Внешние государственные системы, участвующие в процессе онлайн-сделки")
System_Ext(cloud, "Облачный провайдер", "Инфраструктурные мощности и управляемые сервисы")
System_Ext(dc, "Собственный ЦОД / приватное облако", "Основная инфраструктурная площадка компании")
System_Ext(firewall, "Межсетевой экран", "Контролирует внешний доступ клиентов и собственников к системам компании")
System_Ext(smartHomePlatform, "Платформа партнёра «Умный дом»", "Предоставляет функции интеллектуального домофона и интеллектуального шлагбаума")

Rel(customer, firewall, "Получает доступ через")
Rel(owner, firewall, "Получает доступ через")

Rel(firewall, mainSystem, "Обеспечивает доступ к онлайн-сервисам")

Rel(customer, mainSystem, "Подбирает, бронирует и покупает недвижимость, проходит онлайн-тур и онлайн-сделку")
Rel(owner, mainSystem, "Оплачивает ЖКУ, получает информацию от УК, следит за ремонтом и управляет сервисами умного дома")
Rel(manager, mainSystem, "Использует бизнес-системы в операционной деятельности")
Rel(analyst, mainSystem, "Контролирует безопасность, аудит и архитектурные изменения")

Rel(mainSystem, mc, "Интегрируется по API для оплаты ЖКУ и получения данных о доме")
Rel(mainSystem, gov, "Интегрируется при проведении онлайн-сделки")
Rel(mainSystem, cloud, "Использует облачные ресурсы для масштабирования, доработки и тестирования")
Rel(mainSystem, dc, "Развёрнут в приватном облаке и собственном ЦОД")
Rel(mainSystem, smartHomePlatform, "Передаёт команды и получает статусы домофона и шлагбаума")
Rel(smartHomePlatform, mainSystem, "Передаёт события доступа, распознавания лиц и автомобильных номеров")

SHOW_LEGEND()
@enduml